{
  "name": "lite-gateway-ui",
  "version": "1.0.0",
  "description": "Lite Gateway 管理后台前端 - Vue3 + TypeScript + Pinia + Ant Design Vue",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "pinia": "^2.1.7",
    "axios": "^1.6.2",
